pipeline {
    agent any

    stages {
        stage('CODE') {
            steps {
                git branch: 'main', url: 'https://github.com/CodeWithSaikiran/static-node-server'
            }
        }
        stage('BUILD') {
            steps {
            sh 'docker build -t $IMAGE_NAME .'
            }
        }
        stage('Registry'){
            steps{
                script {
            withCredentials([usernamePassword(credentialsId: 'docker-hub-creds', passwordVariable: 'DOCKER_HUB_PASSWORD', usernameVariable: 'DOCKER_HUB_USER')]) {
                sh "echo \$DOCKER_HUB_PASSWORD | docker login -u \$DOCKER_HUB_USER --password-stdin"
                sh "docker tag $IMAGE_NAME saikiran0809/myrepo:$IMAGE_NAME"
                sh "docker push saikiran0809/myrepo:$IMAGE_NAME"
            }
                }
            }
        }
        stage('RUN'){
            steps{
                sh 'docker run -itd --name $CONATINER_NAME -p $PORT_NUM:3000 $IMAGE_NAME'
            }
        }
    }
}
